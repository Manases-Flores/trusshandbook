  useEffect(()=>{
    if(running){timerRef.current=setInterval(()=>setTime(t=>t+10),10);}
    else{clearInterval(timerRef.current);}
    return()=>clearInterval(timerRef.current);
  },[running]);
  const fmtTime=ms=>{const s=Math.floor(ms/1000),c=Math.floor((ms%1000)/10);return s+"."+String(c).padStart(2,"0")+"s";};
  const pop=(ri,ci)=>{
    setBubbles(prev=>{
      const next=prev.map(r=>r.map(b=>({...b})));
      if(next[ri][ci].popped)return next;
      if(!running&&!done)setRunning(true);
      next[ri][ci].popped=true;
      if(next.every(r=>r.every(b=>b.popped))){setRunning(false);setDone(true);onComplete();setBestTime(p=>p===null||time+10<p?time+10:p);}
      return next;
    });
