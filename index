          {emoji:"🛡️",title:"Objections",desc:"21 handled & ready",color:"#e67e22",id:"objections"},
          {emoji:"💬",title:"Text Template",desc:"Send mid-call",color:"#c0392b",id:"text"},
          {emoji:"📋",title:"Our Programs",desc:"Every product we offer",color:"#16a085",id:"programs"},
        ].map((c,i)=>(
          <div key={i} onClick={()=>onNav(c.id)} style={{background:"#fff",borderRadius:14,padding:"16px 14px",border:"1px solid #dce8ff",cursor:"pointer"}}>
            <div style={{fontSize:24}}>{c.emoji}</div>
            <div style={{fontWeight:700,fontSize:14,color:"#1e3a5f",marginTop:6}}>{c.title}</div>
            <div style={{fontSize:12,color:"#999",marginTop:2}}>{c.desc}</div>
            <div style={{marginTop:10,height:3,borderRadius:3,background:c.color,width:"40%"}}/>
          </div>
        ))}
      </div>
    </div>
  );
}

function App(){
  const [active,setActive]=useState(null);
  const [tipIdx,setTipIdx]=useState(0);
  const [search,setSearch]=useState("");
  const [activeTag,setActiveTag]=useState("All");
  const [openObj,setOpenObj]=useState(null);
  const [openProg,setOpenProg]=useState(null);
  const [showCalc,setShowCalc]=useState(false);
  const [showBubble,setShowBubble]=useState(false);
  const [showNurture,setShowNurture]=useState(false);
  const [showNfty,setShowNfty]=useState(false);
  const [nftyForm,setNftyForm]=useState({...BLANK_FORM});
  const [nftyResult,setNftyResult]=useState(null);
  const [completions,setCompletions]=useState(0);
  const dinoTriggerRef=useRef(null);
  const filtered=objections.filter(o=>(activeTag==="All"||o.tag===activeTag)&&o.q.toLowerCase().includes(search.toLowerCase()));

  return(
    <div style={{fontFamily:"system-ui,sans-serif",background:"#f0f4ff",minHeight:"100vh",padding:"20px 16px 120px"}}>
      <div style={{maxWidth:720,margin:"0 auto"}}>
        {active!==null&&(
          <div style={{display:"flex",gap:8,overflowX:"auto",marginBottom:20,paddingBottom:4}}>
            <button onClick={()=>setActive(null)} style={{flexShrink:0,background:"#fff",color:"#1e3a5f",border:"2px solid #dce8ff",borderRadius:12,padding:"10px 16px",cursor:"pointer",fontWeight:700,fontSize:13}}>← Home</button>
            {navItems.map(n=>(
              <button key={n.id} onClick={()=>setActive(n.id)} style={{flexShrink:0,background:active===n.id?"#1e3a5f":"#fff",color:active===n.id?"#fff":"#1e3a5f",border:"2px solid "+(active===n.id?"#1e3a5f":"#dce8ff"),borderRadius:12,padding:"10px 16px",cursor:"pointer",fontWeight:700,fontSize:13,whiteSpace:"nowrap"}}>
                {n.emoji} {n.label}
              </button>
            ))}
          </div>
        )}
        {active===null&&<HomePage onNav={setActive} tipIdx={tipIdx} onNextTip={()=>setTipIdx(t=>(t+1)%tips.length)}/>}
        {active==="process"&&<SalesProcessPanel/>}
        {active==="loanprocess"&&(
          <Panel title="📁 Loan Process" badge="⏱️ 25–30 days from submission to funding">
            <p style={{fontSize:13,color:"#5a7a9f",marginTop:0,marginBottom:20}}>Know this cold — your borrower will ask, and your answer builds trust.</p>
            {loanProcessSteps.map((s,i)=>(
              <div key={s.step} style={{display:"flex",gap:14,marginBottom:i===loanProcessSteps.length-1?0:16}}>
                <div style={{display:"flex",flexDirection:"column",alignItems:"center"}}>
                  <div style={{minWidth:36,height:36,background:s.funded?"#f0c040":"#1e3a5f",color:s.funded?"#1e3a5f":"#fff",borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:700,fontSize:15,flexShrink:0}}>{s.icon}</div>
                  {i<loanProcessSteps.length-1&&<div style={{width:2,flex:1,background:"#dce8ff",marginTop:4,marginBottom:4}}/>}
                </div>
                <div style={{paddingBottom:8,flex:1}}>
                  <div style={{fontWeight:700,color:s.funded?"#f0c040":"#1e3a5f",fontSize:15}}>Step {s.step}: {s.title}</div>
                  <div style={{color:"#444",fontSize:13,marginTop:4,lineHeight:1.6}}>{s.detail}</div>
                </div>
              </div>
            ))}
            <div style={{background:"#1e3a5f",borderRadius:12,padding:"16px 18px",marginTop:20,textAlign:"center"}}>
              <div style={{fontSize:28,marginBottom:6}}>🎉</div>
              <div style={{fontWeight:800,color:"#f0c040",fontSize:16}}>Funded = Done</div>
              <div style={{fontSize:13,color:"#a0b4cc",marginTop:4}}>Average timeline: 25–30 days from submission to funding.</div>
            </div>
          </Panel>
        )}
        {active==="script"&&(
          <Panel title="📞 Call Script">
            {scriptSections.map(s=>(
              <div key={s.label} style={{marginBottom:20}}>
                <div style={{fontWeight:700,color:"#1e3a5f",fontSize:13,textTransform:"uppercase",letterSpacing:1,marginBottom:8}}>{s.label}</div>
                {s.lines.map((l,i)=><div key={i} style={{background:"#f0f4ff",borderLeft:"3px solid #4a7fd4",borderRadius:"0 8px 8px 0",padding:"10px 12px",marginBottom:8,fontSize:14,color:"#222",lineHeight:1.6}}>{l}</div>)}
              </div>
            ))}
          </Panel>
        )}
        {active==="objections"&&(
          <Panel title="🛡️ Objection Handlers">
            <div style={{background:"#1e3a5f",borderRadius:10,padding:"12px 16px",marginBottom:16,textAlign:"center"}}>
              <span style={{color:"#f0c040",fontStyle:"italic",fontSize:13,fontWeight:600}}>"Every objection is simply a request for more certainty."</span>
            </div>
            <input placeholder="🔍 Search objections..." value={search} onChange={e=>{setSearch(e.target.value);setOpenObj(null);}} style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #dce8ff",fontSize:14,marginBottom:12,boxSizing:"border-box",outline:"none"}}/>
            <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:16}}>
              {tags.map(t=><button key={t} onClick={()=>{setActiveTag(t);setOpenObj(null);}} style={{padding:"5px 12px",borderRadius:20,border:"none",cursor:"pointer",fontSize:12,fontWeight:700,background:activeTag===t?(tagColors[t]||"#1e3a5f"):"#eef2ff",color:activeTag===t?"#fff":"#555"}}>{t}</button>)}
            </div>
            {filtered.map((o,i)=>(
              <div key={i} style={{border:"1px solid #dce8ff",borderRadius:10,marginBottom:10,overflow:"hidden"}}>
                <button onClick={()=>setOpenObj(openObj===i?null:i)} style={{width:"100%",background:openObj===i?"#1e3a5f":"#fff",border:"none",padding:"12px 14px",cursor:"pointer",textAlign:"left",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                  <div style={{display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}}>
                    <span style={{background:tagColors[o.tag],color:"#fff",fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:10}}>{o.tag}</span>
                    <span style={{fontWeight:600,fontSize:14,color:openObj===i?"#fff":"#1e3a5f"}}>"{o.q}"</span>
                  </div>
                  <span style={{color:openObj===i?"#f0c040":"#aaa",fontSize:16}}>{openObj===i?"▲":"▼"}</span>
                </button>
                {openObj===i&&(
                  <div style={{padding:"12px 14px",background:"#f8faff"}}>
                    <div style={{fontSize:12,color:"#888",marginBottom:8}}>🧠 <em>{o.psychology}</em></div>
                    <div style={{background:"#f0fff4",borderLeft:"3px solid #27ae60",borderRadius:"0 8px 8px 0",padding:"10px 12px",fontSize:14,color:"#222",lineHeight:1.6}}>{o.a}</div>
                  </div>
                )}
              </div>
            ))}
          </Panel>
        )}
        {active==="text"&&<TextPanel/>}
        {active==="programs"&&(
          <Panel title="📋 Our Programs">
            <p style={{fontSize:13,color:"#5a7a9f",marginTop:0,marginBottom:16}}>When the automated HELOC isn't the right fit, here's what else we have.</p>
            {programs.map((p,i)=>(
              <div key={i} style={{border:"1px solid #dce8ff",borderRadius:12,marginBottom:12,overflow:"hidden"}}>
                <button onClick={()=>setOpenProg(openProg===i?null:i)} style={{width:"100%",background:openProg===i?"#1e3a5f":"#fff",border:"none",padding:"14px 16px",cursor:"pointer",textAlign:"left",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                  <div style={{display:"flex",alignItems:"center",gap:12}}>
                    <span style={{fontSize:22}}>{p.emoji}</span>
                    <div>
                      <div style={{fontWeight:700,fontSize:15,color:openProg===i?"#fff":"#1e3a5f"}}>{p.name}</div>
                      <span style={{background:p.tagColor,color:"#fff",fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:10,display:"inline-block",marginTop:3}}>{p.tag}</span>
                    </div>
                  </div>
                  <span style={{color:openProg===i?"#f0c040":"#aaa",fontSize:16}}>{openProg===i?"▲":"▼"}</span>
                </button>
                {openProg===i&&(
                  <div style={{padding:"14px 16px",background:"#f8faff"}}>
                    <div style={{marginBottom:10}}>
                      <div style={{fontSize:11,fontWeight:700,color:"#5a7a9f",textTransform:"uppercase",marginBottom:4}}>When to use it</div>
                      <div style={{fontSize:14,color:"#222",lineHeight:1.6}}>{p.when}</div>
                    </div>
                    <div style={{marginBottom:12}}>
                      <div style={{fontSize:11,fontWeight:700,color:"#5a7a9f",textTransform:"uppercase",marginBottom:6}}>Key highlights</div>
                      <div style={{display:"flex",flexWrap:"wrap",gap:6}}>{p.highlights.map((h,j)=><span key={j} style={{background:"#eef2ff",color:"#1e3a5f",fontSize:12,fontWeight:600,padding:"4px 10px",borderRadius:8}}>{h}</span>)}</div>
                    </div>
                    <div style={{background:"#1e3a5f",borderRadius:8,padding:"8px 12px",display:"inline-block",marginBottom:p.transfer?14:0}}>
                      <span style={{fontSize:11,color:"#a0b4cc",fontWeight:600}}>MIN FICO: </span>
                      <span style={{fontSize:13,color:"#f0c040",fontWeight:800}}>{p.fico}</span>
                    </div>
                    {p.transfer&&(
                      <div style={{background:p.transfer.color+"15",border:"1px solid "+p.transfer.color+"40",borderRadius:10,padding:14}}>
                        <div style={{fontSize:12,fontWeight:700,color:p.transfer.color,textTransform:"uppercase",marginBottom:10}}>📲 {p.transfer.label}</div>
                        <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
                          {p.transfer.contacts.map((c,j)=>(
                            <div key={j} style={{background:"#fff",borderRadius:10,padding:"8px 14px",border:"1px solid "+p.transfer.color+"40"}}>
                              <div style={{fontWeight:800,fontSize:14,color:"#1e3a5f"}}>{c.name}</div>
                              <div style={{fontSize:11,color:"#888",marginTop:2}}>{c.role}</div>
                            </div>
                          ))}
                        </div>
                        {p.transfer.note&&<div style={{fontSize:12,color:"#666",fontStyle:"italic",marginTop:8}}>⚠️ {p.transfer.note}</div>}
                      </div>
                    )}
                  </div>
                )}
              </div>
            ))}
          </Panel>
        )}
      </div>
      <div style={{position:"fixed",bottom:24,right:24,display:"flex",flexDirection:"column",gap:10,zIndex:999}}>
        <button onClick={()=>setShowNfty(true)} style={{background:"linear-gradient(135deg,#1e3a5f,#4a7fd4)",color:"#f0c040",border:"none",borderRadius:"50px",padding:"12px 18px",cursor:"pointer",fontWeight:800,fontSize:13,boxShadow:"0 4px 20px rgba(0,0,0,0.2)"}}>⚡ NFTY?</button>
        <button onClick={()=>setShowNurture(true)} style={{background:"#c0392b",color:"#fff",border:"none",borderRadius:"50px",padding:"12px 18px",cursor:"pointer",fontWeight:700,fontSize:13,boxShadow:"0 4px 20px rgba(0,0,0,0.15)"}}>🌱 Nurture</button>
        <button onClick={()=>setShowBubble(true)} style={{background:"#f0c040",color:"#1e3a5f",border:"none",borderRadius:"50px",padding:"12px 18px",cursor:"pointer",fontWeight:700,fontSize:13,boxShadow:"0 4px 20px rgba(0,0,0,0.15)"}}>🫧 SLICE Wrap</button>
        <button onClick={()=>setShowCalc(true)} style={{background:"#1e3a5f",color:"#fff",border:"none",borderRadius:"50px",padding:"12px 18px",cursor:"pointer",fontWeight:700,fontSize:13,boxShadow:"0 4px 20px rgba(0,0,0,0.15)"}}>🧮 Calculator</button>
      </div>
      {showNurture&&<NurtureModal onClose={()=>setShowNurture(false)}/>}
      {showCalc&&<CalcModal onClose={()=>setShowCalc(false)}/>}
      {showBubble&&<BubbleWrap onClose={()=>setShowBubble(false)} completions={completions} onComplete={()=>setCompletions(c=>c+1)}/>}
      {showNfty&&<NftyChecker onClose={()=>setShowNfty(false)} form={nftyForm} setForm={setNftyForm} result={nftyResult} setResult={setNftyResult}/>}
      <DinoRunner triggerRef={dinoTriggerRef}/>
      <button onClick={()=>dinoTriggerRef.current&&dinoTriggerRef.current()} style={{position:"fixed",top:0,left:0,width:40,height:40,opacity:0,cursor:"default",zIndex:10000,border:"none",background:"transparent"}}/>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
