function StandardCalc(){
  const [display,setDisplay]=useState("0");
  const [expr,setExpr]=useState("");
  const [justEvaled,setJustEvaled]=useState(false);
  const stateRef=useRef({display:"0",expr:"",justEvaled:false});
  stateRef.current={display,expr,justEvaled};
  const handleKey=useCallback((k)=>{
    const{display:d,expr:e,justEvaled:je}=stateRef.current;
    if(k==="C"){setDisplay("0");setExpr("");setJustEvaled(false);return;}
    if(k==="⌫"){setDisplay(d.length>1?d.slice(0,-1):"0");return;}
    if(k==="="){try{const result=Function('"use strict";return('+(e+d).replace(/×/g,"*").replace(/÷/g,"/")+')')(  );const rounded=parseFloat(result.toFixed(10));setDisplay(isFinite(rounded)?String(rounded):"Error");setExpr("");setJustEvaled(true);}catch{setDisplay("Error");setExpr("");}return;}
    if(k==="%"){setDisplay(String(parseFloat(d)/100));return;}
    if(k==="+/-"){setDisplay(d.startsWith("-")?d.slice(1):"-"+d);return;}
    if(["+","-","×","÷"].includes(k)){setExpr(e+d+k);setDisplay("0");setJustEvaled(false);return;}
    if(k==="."){if(je){setDisplay("0.");setJustEvaled(false);return;}setDisplay(d.includes(".")?d:d+".");return;}
    if(je){setDisplay(k);setJustEvaled(false);return;}
    setDisplay(d==="0"?k:d+k);
  },[]);
  const fmtD=d=>{if(d==="Error")return"Error";const p=d.split(".");p[0]=p[0].replace(/\B(?=(\d{3})+(?!\d))/g,",");return p.join(".");};
  const topRow=["C","+/-","%"];
  const leftRows=[["7","8","9"],["4","5","6"],["1","2","3"],["0",".","⌫"]];
  const rightCol=["÷","×","-","+","="];
  const btnS=k=>({width:"100%",padding:"15px 0",borderRadius:12,border:"none",cursor:"pointer",fontWeight:700,fontSize:16,background:["+","-","×","÷"].includes(k)?"#1e3a5f":k==="="?"#f0c040":["C","+/-","%","⌫"].includes(k)?"#dce8ff":"#f0f4ff",color:["+","-","×","÷"].includes(k)?"#fff":k==="="?"#1e3a5f":"#1e3a5f"});
  return(
    <div style={{maxWidth:340,margin:"0 auto"}}>
      <div style={{background:"#1e3a5f",borderRadius:14,padding:"16px 20px",textAlign:"right",marginBottom:14}}>
        <div style={{fontSize:display.length>12?22:32,fontWeight:800,color:"#fff",wordBreak:"break-all"}}>{fmtD(display)}</div>
      </div>
      <div style={{display:"flex",gap:8}}>
        <div style={{flex:3,display:"flex",flexDirection:"column",gap:8}}>
          <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>{topRow.map(k=><button key={k} onClick={()=>handleKey(k)} style={btnS(k)}>{k}</button>)}</div>
          {leftRows.map((row,ri)=><div key={ri} style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>{row.map(k=><button key={k} onClick={()=>handleKey(k)} style={btnS(k)}>{k}</button>)}</div>)}
        </div>
        <div style={{flex:1,display:"flex",flexDirection:"column",gap:8}}>{rightCol.map(k=><button key={k} onClick={()=>handleKey(k)} style={{...btnS(k),flex:1,padding:"0"}}>{k}</button>)}</div>
      </div>
    </div>
  );
}

