        </div>
        <div style={{display:"flex",flexDirection:"column",gap:6}}>
          {bubbles.map((row,ri)=>(
            <div key={ri} style={{display:"flex",alignItems:"center",gap:5}}>
              <div style={{width:16,fontWeight:800,fontSize:13,color:ROW_COLORS[ri],textAlign:"center"}}>{LETTERS[ri]}</div>
