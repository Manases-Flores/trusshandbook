function DinoRunner({triggerRef}){
  const [phase,setPhase]=useState("hidden");
  const [msg,setMsg]=useState("");
  const [showBubble,setShowBubble]=useState(false);
  const [legFrame,setLegFrame]=useState(0);
  const [dinoX,setDinoX]=useState(-120);
  const [cactusX1,setCactusX1]=useState(null);
  const [cactusX2,setCactusX2]=useState(null);
  const scheduleRef=useRef(null);
  const animRef=useRef(null);
  const legRef=useRef(null);
  const phaseRef=useRef(phase);
  phaseRef.current=phase;
  const STOP_X=Math.min(window.innerWidth*0.12,80);

  const startDino=useCallback(()=>{
    if(phaseRef.current!=="hidden")return;
    setMsg(dinoMessages[Math.floor(Math.random()*dinoMessages.length)]);
    setCactusX1(window.innerWidth*0.45+Math.random()*60);
    setCactusX2(window.innerWidth*0.65+Math.random()*60);
    setDinoX(-120);setShowBubble(false);setPhase("walkin");
  },[]);

  useEffect(()=>{if(triggerRef)triggerRef.current=startDino;},[startDino,triggerRef]);
  useEffect(()=>{scheduleRef.current=setTimeout(startDino,45*60*1000);return()=>clearTimeout(scheduleRef.current);},[]);

  useEffect(()=>{
    if(phase==="walkin"||phase==="walkout"){legRef.current=setInterval(()=>setLegFrame(f=>1-f),180);}
    else{clearInterval(legRef.current);setLegFrame(0);}
    return()=>clearInterval(legRef.current);
  },[phase]);

  useEffect(()=>{
    if(phase!=="walkin")return;
    let x=-120;const target=STOP_X;
    animRef.current=setInterval(()=>{x+=4;setDinoX(x);if(x>=target){clearInterval(animRef.current);setDinoX(target);setPhase("talking");setTimeout(()=>setShowBubble(true),300);setTimeout(()=>{setShowBubble(false);setTimeout(()=>setPhase("walkout"),400);},4500);}},16);
    return()=>clearInterval(animRef.current);
  },[phase]);

  useEffect(()=>{
    if(phase!=="walkout")return;
    let x=STOP_X;
    animRef.current=setInterval(()=>{x-=5;setDinoX(x);if(x<-140){clearInterval(animRef.current);setPhase("hidden");setCactusX1(null);setCactusX2(null);scheduleRef.current=setTimeout(startDino,45*60*1000);}},16);
    return()=>clearInterval(animRef.current);
  },[phase]);

  if(phase==="hidden")return null;
  const dinoSrc=`data:image/svg+xml,${legFrame===0?DINO_SVG:DINO_SVG2}`;
  const cactusSrc=`data:image/svg+xml,${CACTUS_SVG}`;
  const groundY=88;
  return(
    <div style={{position:"fixed",inset:0,bottom:0,zIndex:9999,pointerEvents:"none",overflow:"hidden"}}>
      <style>{`@keyframes bubblePop{0%{transform:scale(0);opacity:0;}60%{transform:scale(1.1);opacity:1;}100%{transform:scale(1);opacity:1;}}.dino-bubble-in{animation:bubblePop 0.35s ease forwards;}`}</style>
      <div style={{position:"absolute",bottom:groundY-4,left:0,right:0,height:2,background:"#535353",opacity:0.25}}/>
      {cactusX1&&<img src={cactusSrc} alt="" style={{position:"absolute",bottom:groundY-2,left:cactusX1,width:36,height:54,imageRendering:"pixelated"}}/>}
      {cactusX2&&<img src={cactusSrc} alt="" style={{position:"absolute",bottom:groundY-2,left:cactusX2,width:28,height:42,imageRendering:"pixelated"}}/>}
      <div style={{position:"absolute",bottom:groundY,left:dinoX,display:"flex",flexDirection:"column",alignItems:"flex-start"}}>
        {showBubble&&(
          <div className="dino-bubble-in" style={{background:"#1e3a5f",color:"#f0c040",fontWeight:800,fontSize:12,padding:"9px 14px",borderRadius:12,marginBottom:8,marginLeft:4,boxShadow:"0 3px 14px rgba(0,0,0,0.25)",fontFamily:"system-ui,sans-serif",maxWidth:240,lineHeight:1.4,position:"relative"}}>
            {msg}
            <div style={{position:"absolute",bottom:-7,left:18,width:0,height:0,borderLeft:"7px solid transparent",borderRight:"7px solid transparent",borderTop:"7px solid #1e3a5f"}}/>
          </div>
        )}
        <img src={dinoSrc} alt="dino" style={{width:64,height:64,imageRendering:"pixelated",transform:phase==="walkout"?"scaleX(-1)":"scaleX(1)"}}/>
      </div>
    </div>
  );
}

