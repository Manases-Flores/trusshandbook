const BLANK_FORM={fico:"",cltv:"",loanAmount:"",dti:"",occupancy:"primary",lienPosition:"2nd",propertyType:"sfr",empType:"w2"};

function checkNFTY(f){
  const fico=parseInt(f.fico)||0,cltv=parseFloat(f.cltv)||0,loanAmt=parseFloat(f.loanAmount)||0,dti=parseFloat(f.dti)||0,occ=f.occupancy,lien=f.lienPosition,propType=f.propertyType;
  const nftyIssues=[],nftyWarnings=[];
  if(fico<640)nftyIssues.push("FICO below 640 minimum");
  if(occ==="investment"&&fico<700)nftyIssues.push("Investment property requires 700+ FICO for NFTY");
  if(loanAmt<25000)nftyIssues.push("Loan amount below $25,000 minimum");
  if(loanAmt>500000)nftyIssues.push("Loan amount exceeds $500,000 max");
  if(fico>=680&&dti>50)nftyIssues.push("DTI exceeds 50% max (680+ FICO)");
  if(fico>=640&&fico<680&&dti>45)nftyIssues.push("DTI exceeds 45% max (640–679 FICO)");
  if(lien==="3rd")nftyIssues.push("NFTY does not offer 3rd lien position (1st or 2nd only)");
  if(loanAmt>=350000)nftyWarnings.push("⚠️ Loan ≥ $350k — ALTA title policy required");
  if(loanAmt>0&&loanAmt<350000)nftyWarnings.push("ℹ️ Loan < $350k — Legal & Vesting Report only, no title insurance required");
  if(lien==="2nd")nftyWarnings.push("ℹ️ Hazard insurance NOT required for 2nd lien HELOCs");
  if(occ==="investment")nftyWarnings.push("ℹ️ Investment properties limited to 10 financed properties");
  nftyWarnings.push("⚠️ LLCs are ineligible — must close as Sole Ownership, Joint, or Revocable Trust");
  const closingTime=occ==="primary"?"5 business days + 3-day rescission":"As few as 5 business days, same-day funding";
  nftyWarnings.push("⏱️ Closing timeline: "+closingTime);
  let nftyCLTV=0;
  if(occ==="primary"){if(fico>=700)nftyCLTV=80;else if(fico>=680)nftyCLTV=75;else if(fico>=660)nftyCLTV=70;else if(fico>=640)nftyCLTV=65;}
  else if(occ==="second"){if(fico>=740)nftyCLTV=75;else if(fico>=720)nftyCLTV=70;else if(fico>=680)nftyCLTV=65;else if(fico>=660)nftyCLTV=60;else if(fico>=640)nftyCLTV=60;}
  else if(occ==="investment"&&fico>=700)nftyCLTV=70;
  if(nftyCLTV>0&&cltv>nftyCLTV)nftyIssues.push("CLTV "+cltv+"% exceeds NFTY max of "+nftyCLTV+"% for this scenario");
  const figureIssues=[],figureWarnings=[];
  if(occ==="primary"&&fico<640)figureIssues.push("FICO below 640 minimum for Deep Haven primary");
  if((occ==="second"||occ==="investment")&&fico<680)figureIssues.push("FICO below 680 minimum for Deep Haven non-owner occupied");
  if(loanAmt<25000)figureIssues.push("Loan amount below $25,000 minimum");
  if(loanAmt>750000)figureIssues.push("Loan amount exceeds $750,000 max");
  if(dti>=50)figureIssues.push("DTI must be under 50%");
  if(lien==="3rd"&&fico<680)figureIssues.push("3rd lien requires 680+ FICO for Deep Haven");
  if(lien==="3rd"&&cltv>70)figureIssues.push("3rd lien capped at 70% CLTV for Deep Haven");
  if(lien==="3rd"&&(occ==="second"||occ==="investment"))figureIssues.push("3rd lien only available on primary for Deep Haven");
  figureWarnings.push("⚠️ EPO triggered if >90% is paid off within 16 weeks");
  figureWarnings.push("⚠️ Title seasoning: 90 days from purchase or 45 days from prior refi");
  figureWarnings.push("ℹ️ Draw period options: 2yr, 3yr, 4yr, or 5yr — 100% initial draw required");
  let figureCLTV=0;
  if(occ==="primary"){
    if(lien==="1st")figureCLTV=fico>=740?85:fico>=680?80:75;
    else if(lien==="2nd")figureCLTV=fico>=740?85:fico>=680?85:fico>=660?80:75;
    else if(lien==="3rd")figureCLTV=70;
  }else{figureCLTV=lien==="1st"?80:70;}
  if(figureCLTV>0&&cltv>figureCLTV)figureIssues.push("CLTV "+cltv+"% exceeds Deep Haven max of "+figureCLTV+"% for this scenario");
  return{nftyGood:nftyIssues.length===0,figureGood:figureIssues.length===0,nftyIssues,figureIssues,nftyWarnings,figureWarnings,nftyCLTV,figureCLTV};
}

