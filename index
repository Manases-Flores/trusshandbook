        {tab==="standard"&&<StandardCalc/>}
        {tab==="heloc"&&<div>
          <label style={lbl}>Loan Amount</label>{inp(hAmount,setHAmount,"e.g. 50000")}
          <label style={lbl}>Interest Rate (%)</label>{inp(hRate,setHRate,"e.g. 8.5")}
          <label style={lbl}>Term (Years)</label>{inp(hYears,setHYears,"e.g. 10")}
          {(helocPmt||ioPmt)&&<div style={resBox}><div style={{display:"flex",justifyContent:"space-between",flexWrap:"wrap",gap:12}}>
            {helocPmt&&<div><div style={resLbl}>Est. Monthly Payment</div><div style={resVal}>{fmt(helocPmt)}</div><div style={resSub}>Total over {hYears} yrs: {fmt(helocPmt*hYears*12)}</div></div>}
